{
  "name": "@openmost/nuxt-matomo",
  "version": "2.1.4",
  "description": "Matomo for Nuxt",
  "repository": "openmost/nuxt-matomo",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npx nuxi dev playground",
    "dev:build": "npx nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && npx nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^3.18.1 || ^4.0.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^1.7.0",
    "@nuxt/eslint-config": "^0.7.5",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "latest",
    "changelogen": "^0.5.7",
    "eslint": "^9.18.0",
    "nuxt": "^4.4.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3",
    "vue-tsc": "^2.2.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
